{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "packages/frontend/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/**",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
